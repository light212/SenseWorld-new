# ============================================================
# SenseWorld AI 多模态对话平台 - 环境变量模板
# 复制此文件为 .env 并填入真实值，切勿将 .env 提交至版本库
# ============================================================

# ---- 数据库 ----
# MySQL 连接字符串（本地开发使用 Docker Compose 启动的 MySQL）
DATABASE_URL="mysql://senseworld:password@localhost:3306/senseworld"

# ---- NextAuth.js ----
# Session 加密密钥，使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET="your-secret-key-at-least-32-chars"
# 应用访问地址
NEXTAUTH_URL="http://localhost:3000"

# ---- 管理后台 JWT ----
# 使用 openssl rand -base64 32 生成，生产环境必须替换
JWT_SECRET="your-jwt-secret-at-least-32-chars"
# JWT 有效期（可选，默认 8h）
JWT_EXPIRES_IN="8h"

# ---- 管理员初始账号（仅 seed 时使用）----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-immediately"

# ---- AI 模型（可选，运营配置面板中的设置优先于此处）----
AI_PROVIDER="openai"
AI_API_KEY="sk-your-key-here"
AI_MODEL="gpt-4o"

# ---- 语音服务（可选，运营配置面板中的设置优先于此处）----
SPEECH_PROVIDER="azure"
SPEECH_API_KEY="your-speech-api-key"

# ---- Avatar 服务（预留）----
AVATAR_PROVIDER=""
AVATAR_API_KEY=""

# ---- System Prompt（可选，运营配置面板中的设置优先于此处）----
SYSTEM_PROMPT="You are a helpful assistant."

# ---- Docker Compose 数据库配置（仅 Docker 环境使用）----
MYSQL_ROOT_PASSWORD="rootpassword"
MYSQL_DATABASE="senseworld"
MYSQL_USER="senseworld"
MYSQL_PASSWORD="password"
