# ============================================================
# SenseWorld AI 多模态对话平台 - 环境变量模板
# 复制此文件为 .env 并填入真实值，切勿将 .env 提交至版本库
# ============================================================

# ---- 数据库 ----
# MySQL 连接字符串（本地开发使用 Docker Compose 启动的 MySQL）
DATABASE_URL="mysql://senseworld:password@localhost:3306/senseworld"

# ---- NextAuth.js ----
# Session 加密密钥，使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET="your-secret-key-at-least-32-chars"
# 应用访问地址
NEXTAUTH_URL="http://localhost:3000"

# ---- 管理员初始账号（仅 seed 时使用）----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-immediately"

# ---- AI 模型（可选，运营配置优先于环境变量）----
ANTHROPIC_API_KEY="sk-ant-your-key-here"
OPENAI_API_KEY="sk-your-key-here"

# ---- 语音服务（可选）----
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="eastasia"

# ---- Docker Compose 数据库配置（仅 Docker 环境使用）----
MYSQL_ROOT_PASSWORD="rootpassword"
MYSQL_DATABASE="senseworld"
MYSQL_USER="senseworld"
MYSQL_PASSWORD="password"
